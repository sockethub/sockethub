{
  "name": "@sockethub/platform-feeds",
  "description": "A sockethub platform module implementing RSS/Atom functionality",
  "version": "4.0.0-alpha.15",
  "type": "module",
  "private": false,
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "LGPL-3.0+",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "messaging",
    "activitystreams",
    "activity",
    "streams",
    "protocol",
    "feeds",
    "rss",
    "atom"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/platform-feeds"
  },
  "homepage": "https://github.com/sockethub/sockethub/tree/master/packages/platform-feeds",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules"
  },
  "dependencies": {
    "@sockethub/util": "^1.0.0-alpha.3",
    "html-tags": "^3.3.1",
    "htmlparser2": "^9.1.0",
    "podparse": "^1.6.0"
  },
  "devDependencies": {
    "@sockethub/schemas": "^3.0.0-alpha.15",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "@sockethub/server": "5.0.0-alpha.15"
  },
  "peerDependenciesMeta": {
    "@sockethub/server": {
      "optional": true
    }
  },
  "gitHead": "7f85c0aa1c317b56336af4149b29dc78afc5f2bd",
  "types": "./dist/index.d.ts"
}
