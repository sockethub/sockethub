{
  "name": "@sockethub/data-layer",
  "description": "Storing and RPC of data for Sockethub",
  "version": "1.0.0-alpha.13",
  "type": "module",
  "private": false,
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "messaging",
    "redis",
    "data layer",
    "rpc",
    "data store"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/data-layer"
  },
  "homepage": "https://github.com/sockethub/sockethub/tree/master/packages/data-layer",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules",
    "doc": "typedoc --options typedoc.json",
    "test": "bun test src/",
    "test:integration": "bun test ./integration/redis.integration.ts"
  },
  "dependencies": {
    "@sockethub/logger": "^1.0.0-alpha.13",
    "@sockethub/schemas": "^3.0.0-alpha.13",
    "@sockethub/util": "^1.0.0-alpha.1",
    "bullmq": "^5.66.5",
    "ioredis": "^5.9.2",
    "secure-store-redis": "^4.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/sinon": "^17.0.4",
    "@types/winston": "^2.4.4",
    "sinon": "^17.0.2",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "winston": "^3.19.0"
  },
  "gitHead": "745e85ac71f3c027f8ef8b8edc49398be8dbaccd",
  "types": "./dist/index.d.ts"
}
