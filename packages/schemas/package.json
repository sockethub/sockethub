{
  "name": "@sockethub/schemas",
  "description": "JSON schema files for validating Sockethub Activity Streams",
  "version": "3.0.0-alpha.15",
  "type": "module",
  "private": false,
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "default": "./dist/context.js"
    },
    "./object-types": {
      "types": "./dist/object-types.d.ts",
      "import": "./dist/object-types.js",
      "default": "./dist/object-types.js"
    },
    "./schemas/json/sockethub-config.json": {
      "default": "./dist/schemas/json/sockethub-config.json"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "sockethub schema",
    "activity streams",
    "activity objects",
    "sockethub platforms"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/schemas"
  },
  "homepage": "https://github.com/sockethub/sockethub/tree/master/packages/schemas",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "build": "bun ./scripts/export-canonical-assets.ts && bun ./scripts/export-json-schema.ts && bun build src/index.ts src/object-types.ts --outdir dist --target node --format esm --sourcemap=external && bun build src/context.ts src/activity-stream-helper.ts --outdir dist --target browser --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "ajv-formats-draft2019": "^1.6.1"
  },
  "gitHead": "7f85c0aa1c317b56336af4149b29dc78afc5f2bd",
  "types": "./dist/index.d.ts"
}
