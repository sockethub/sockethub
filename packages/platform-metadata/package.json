{
  "name": "@sockethub/platform-metadata",
  "version": "1.0.1-alpha.9",
  "description": "Fetch metadata from a given URL",
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "LGPL-3.0+",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "platform",
    "metadata",
    "open graph",
    "website",
    "preview"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/platform-metadata"
  },
  "homepage": "https://github.com/sockethub/sockethub/tree/master/packages/platform-metadata",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules"
  },
  "dependencies": {
    "@sockethub/util": "^1.0.0-alpha.2",
    "open-graph-scraper": "^6.11.0"
  },
  "devDependencies": {
    "@sockethub/schemas": "^3.0.0-alpha.14"
  },
  "peerDependencies": {
    "@sockethub/server": "^5.0.0-alpha.14"
  },
  "gitHead": "4bc8ffa00d29aa78e59e269ac6e5ea9859ec01a8",
  "types": "./dist/index.d.ts"
}
