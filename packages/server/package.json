{
  "name": "@sockethub/server",
  "description": "A polyglot messaging service, server libraries",
  "version": "5.0.0-alpha.12",
  "type": "module",
  "private": false,
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "LGPL-3.0+",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "bin/",
    "res/"
  ],
  "bin": "bin/sockethub",
  "preferGlobal": true,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "messaging",
    "polyglot",
    "unhosted",
    "api",
    "protocols",
    "protocol",
    "irc",
    "xmpp",
    "rss",
    "atom",
    "smtp",
    "imap",
    "email"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/server"
  },
  "homepage": "https://sockethub.org",
  "dependencies": {
    "@sentry/node": "^10.36.0",
    "@sockethub/client": "^5.0.0-alpha.12",
    "@sockethub/crypto": "^1.0.0-alpha.12",
    "@sockethub/data-layer": "^1.0.0-alpha.12",
    "@sockethub/logger": "^1.0.0-alpha.12",
    "@sockethub/schemas": "^3.0.0-alpha.12",
    "@sockethub/util": "^1.0.0-alpha.0",
    "body-parser": "^1.20.4",
    "chalk": "^5.6.2",
    "convict": "^6.2.5",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "jquery": "^3.7.1",
    "socket.io": "^4.8.3"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external && bun build src/platform.ts --outdir dist --target node --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules",
    "dev": "bun run --hot ./bin/sockethub --examples",
    "start": "node ./bin/sockethub",
    "test": "bun test src/",
    "test:integration": "bun test ./integration/*.integration.ts"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/bun": "latest",
    "@types/convict": "^6.1.6",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.25",
    "@types/jquery": "^3.5.33",
    "@types/sinon": "^17.0.4",
    "jaribu": "^2.2.3",
    "sinon": "^17.0.2",
    "web-streams-polyfill": "^3.3.3"
  },
  "optionalDependencies": {
    "@sockethub/examples": "^1.0.0-alpha.12",
    "@sockethub/platform-dummy": "^3.0.0-alpha.12",
    "@sockethub/platform-feeds": "^4.0.0-alpha.12",
    "@sockethub/platform-irc": "^4.0.0-alpha.12",
    "@sockethub/platform-metadata": "^1.0.1-alpha.7",
    "@sockethub/platform-xmpp": "^5.0.0-alpha.12"
  },
  "gitHead": "cc495a5fcf7ce19a8f328a34bbc8cd1439bb67ce",
  "types": "./dist/index.d.ts"
}
