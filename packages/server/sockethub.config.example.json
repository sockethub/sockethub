{
  "$schema": "../schemas/src/schemas/json/sockethub-config.json",
  "examples": true,
  "sockethub": {
    "port": 10550,
    "host": "localhost",
    "path": "/sockethub"
  },
  "logging": {
    "level": "info",
    "fileLevel": "debug",
    "file": "sockethub.log"
  },
  "platforms": [
    "@sockethub/platform-dummy",
    "@sockethub/platform-feeds",
    "@sockethub/platform-irc",
    "@sockethub/platform-xmpp"
  ],
  "packageConfig": {
    "@sockethub/platform-feeds": {
      "connectTimeoutMs": 5000
    }
  },
  "public": {
    "protocol": "http",
    "host": "localhost",
    "port": 10550,
    "path": "/"
  },
  "redis": {
    "url": "redis://127.0.0.1:6379"
  }
}
