{
  "name": "@sockethub/platform-dummy",
  "description": "A sockethub platform dummy module",
  "version": "3.0.0-alpha.14",
  "type": "module",
  "private": false,
  "author": "Nick Jennings <nick@silverbucket.net>",
  "license": "LGPL-3.0+",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sockethub",
    "dummy"
  ],
  "devDependencies": {
    "@sockethub/schemas": "^3.0.0-alpha.14",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "@sockethub/server": "^5.0.0-alpha.14"
  },
  "peerDependenciesMeta": {
    "@sockethub/server": {
      "optional": true
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external",
    "clean": "rm -rf dist",
    "clean:deps": "rm -rf node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockethub/sockethub.git",
    "directory": "packages/platform-dummy"
  },
  "homepage": "https://github.com/sockethub/sockethub/tree/master/packages/platform-dummy",
  "gitHead": "4bc8ffa00d29aa78e59e269ac6e5ea9859ec01a8",
  "types": "./dist/index.d.ts"
}
